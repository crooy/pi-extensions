{
  "name": "pi-cavepeople",
  "version": "0.26.0",
  "description": "Pi extension for delegating tasks to caveman-mode subagents with fresh shell, direnv, and terse responses",
  "author": "Nico Bailon",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/MattDevy/pi-extensions.git",
    "directory": "packages/pi-cavepeople"
  },
  "homepage": "https://github.com/MattDevy/pi-extensions/tree/main/packages/pi-cavepeople#readme",
  "bugs": {
    "url": "https://github.com/MattDevy/pi-extensions/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "subagents",
    "ai",
    "agents",
    "cli",
    "caveman"
  ],
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "pi-subagents": "install.mjs"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "*.mjs",
    "agents/",
    "skills/**/*",
    "prompts/**/*",
    "scripts/",
    "README.md",
    "CHANGELOG.md",
    "banner.png"
  ],
  "main": "./dist/extension/index.js",
  "types": "./dist/extension/index.d.ts",
  "pi": {
    "extensions": [
      "./src/extension/index.ts"
    ],
    "skills": [
      "./skills"
    ],
    "prompts": [
      "./prompts"
    ]
  },
  "scripts": {
    "clean": "rm -rf dist tsconfig.build.tsbuildinfo",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "node --experimental-strip-types --test test/unit/*.test.ts",
    "test:integration": "node --experimental-transform-types --import ./test/support/register-loader.mjs --test test/integration/*.test.ts",
    "test:all": "npm run test:unit && npm run test:integration",
    "lint": "echo 'lint not configured for pi-cavepeople'",
    "check": "npm run test:unit",
    "prepublishOnly": "npm run build",
    "prepack": "test -d dist || { echo 'Error: dist/ missing. Run npm run build first.' && exit 1; }"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-agent-core": {
      "optional": true
    },
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-coding-agent": {
      "optional": true
    }
  },
  "dependencies": {
    "@earendil-works/pi-tui": "^0.74.0",
    "jiti": "^2.7.0",
    "typebox": "^1.2.14"
  },
  "devDependencies": {
    "@earendil-works/pi-agent-core": "^0.79.6",
    "@earendil-works/pi-ai": "^0.74.0",
    "@earendil-works/pi-coding-agent": "^0.74.0",
    "typescript": "^6.0.3"
  }
}
