{
  "name": "pi-always-learning",
  "version": "0.1.0",
  "description": "Caveman memory: watches coding sessions, distills patterns into instincts with confidence scoring. Fire keeps knowledge alive.",
  "type": "module",
  "license": "MIT",
  "author": "Matt Devy",
  "repository": {
    "type": "git",
    "url": "https://github.com/MattDevy/pi-extensions.git",
    "directory": "packages/pi-always-learning"
  },
  "homepage": "https://github.com/MattDevy/pi-extensions/tree/main/packages/pi-always-learning#readme",
  "bugs": {
    "url": "https://github.com/MattDevy/pi-extensions/issues"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "caveman",
    "caveman-learning",
    "instincts",
    "ai",
    "llm",
    "ai-agent",
    "coding-assistant",
    "developer-tools",
    "memory",
    "prompt-engineering"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "pi": {
    "extensions": [
      "dist/index.js"
    ]
  },
  "bin": {
    "pi-cl-analyze": "dist/cli/analyze.js"
  },
  "scripts": {
    "clean": "rm -rf dist *.tsbuildinfo",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "check": "vitest run && eslint src/ && tsc --noEmit",
    "prepublishOnly": "npm run build && npm run check",
    "prepack": "test -d dist || { echo 'Error: dist/ missing. Run npm run build first.' && exit 1; }"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "^0.79.8",
    "@earendil-works/pi-coding-agent": "^0.79.8",
    "@earendil-works/pi-tui": "^0.79.8",
    "@sinclair/typebox": "^0.34.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "optionalDependencies": {
    "@esbuild/linux-x64": "0.28.1",
    "@rollup/rollup-linux-x64-gnu": "4.62.2"
  }
}
