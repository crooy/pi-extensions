{
  "name": "pi-extensions",
  "version": "0.1.0",
  "private": false,
  "description": "🪨 All Pi caveman extensions in one bundle. Fork of MattDevy/pi-extensions.",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  },
  "pi": {
    "extensions": [
      "./packages/pi-caveman/extensions/caveman.ts",
      "./packages/pi-always-learning/dist/index.js",
      "./packages/pi-simple-powers/extensions/simple-powers.ts"
    ],
    "skills": [
      "./packages/pi-simple-powers/skills"
    ],
    "prompts": []
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "caveman",
    "token-saving"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crooy/pi-extensions.git"
  },
  "files": [
    "packages/*/dist/**",
    "packages/*/extensions/**",
    "packages/*/src/**",
    "packages/*/agents/**",
    "packages/*/skills/**",
    "packages/*/prompts/**",
    "packages/*/package.json",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint packages/",
    "check": "npm run check --workspaces --if-present",
    "install-extensions": "bash install-all.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "typescript": "^6.0.3"
  }
}
